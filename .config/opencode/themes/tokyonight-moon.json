{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#222436",
    "bg_dark": "#1e2030",
    "bg_highlight": "#2f334d",
    "fg": "#c8d3f5",
    "fg_dark": "#828bb8",
    "fg_muted": "#636da6",
    "blue": "#82aaff",
    "blue_bright": "#65bcff",
    "cyan": "#86e1fc",
    "green": "#c3e88d",
    "green_bright": "#4fd6be",
    "magenta": "#c099ff",
    "orange": "#ff966c",
    "purple": "#fca7ea",
    "red": "#ff757f",
    "red_dark": "#c53b53",
    "teal": "#4fd6be",
    "yellow": "#ffc777",
    "border": "#1b1d2b",
    "border_highlight": "#589ed7",
    "comment": "#636da6"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue_bright"
    },
    "secondary": {
      "dark": "cyan",
      "light": "cyan"
    },
    "accent": {
      "dark": "teal",
      "light": "teal"
    },
    "error": {
      "dark": "red_dark",
      "light": "red_dark"
    },
    "warning": {
      "dark": "yellow",
      "light": "yellow"
    },
    "success": {
      "dark": "green",
      "light": "green"
    },
    "info": {
      "dark": "blue",
      "light": "blue_bright"
    },
    "text": {
      "dark": "fg",
      "light": "bg"
    },
    "textMuted": {
      "dark": "fg_muted",
      "light": "fg_dark"
    },
    "background": {
      "dark": "bg",
      "light": "fg"
    },
    "backgroundPanel": {
      "dark": "bg_dark",
      "light": "fg_dark"
    },
    "backgroundElement": {
      "dark": "bg_dark",
      "light": "fg"
    },
    "border": {
      "dark": "border",
      "light": "border"
    },
    "borderActive": {
      "dark": "border_highlight",
      "light": "border_highlight"
    },
    "borderSubtle": {
      "dark": "bg_highlight",
      "light": "bg_highlight"
    },
    "diffAdded": {
      "dark": "green",
      "light": "green"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffContext": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffHunkHeader": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffHighlightAdded": {
      "dark": "green_bright",
      "light": "green_bright"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "#2a4556",
      "light": "#c3e88d"
    },
    "diffRemovedBg": {
      "dark": "#4b2a3d",
      "light": "#ff757f"
    },
    "diffContextBg": {
      "dark": "bg_dark",
      "light": "fg_dark"
    },
    "diffLineNumber": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "diffAddedLineNumberBg": {
      "dark": "#2a4556",
      "light": "#c3e88d"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#4b2a3d",
      "light": "#ff757f"
    },
    "markdownText": {
      "dark": "fg",
      "light": "bg"
    },
    "markdownHeading": {
      "dark": "blue",
      "light": "blue_bright"
    },
    "markdownLink": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownLinkText": {
      "dark": "teal",
      "light": "teal"
    },
    "markdownCode": {
      "dark": "green",
      "light": "green"
    },
    "markdownBlockQuote": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "markdownEmph": {
      "dark": "yellow",
      "light": "yellow"
    },
    "markdownStrong": {
      "dark": "orange",
      "light": "orange"
    },
    "markdownHorizontalRule": {
      "dark": "fg_muted",
      "light": "fg_muted"
    },
    "markdownListItem": {
      "dark": "blue",
      "light": "blue_bright"
    },
    "markdownListEnumeration": {
      "dark": "teal",
      "light": "teal"
    },
    "markdownImage": {
      "dark": "cyan",
      "light": "cyan"
    },
    "markdownImageText": {
      "dark": "teal",
      "light": "teal"
    },
    "markdownCodeBlock": {
      "dark": "fg",
      "light": "bg"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "comment"
    },
    "syntaxKeyword": {
      "dark": "magenta",
      "light": "magenta"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "blue"
    },
    "syntaxVariable": {
      "dark": "teal",
      "light": "teal"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green"
    },
    "syntaxNumber": {
      "dark": "magenta",
      "light": "magenta"
    },
    "syntaxType": {
      "dark": "teal",
      "light": "teal"
    },
    "syntaxOperator": {
      "dark": "cyan",
      "light": "cyan"
    },
    "syntaxPunctuation": {
      "dark": "fg",
      "light": "bg"
    }
  }
}
